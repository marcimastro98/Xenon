# AI assistant / internal workspace files — local only, never commit
.github/copilot-instructions.md
.github/skills/
.claude/
AGENTS.md
CORSAIR_SDK_NOTES.md

# Xenon Creator — generated dashboard packs (themes/widgets/backgrounds/pages
# and their import codes). Authored locally by the xenon-creator skill; the
# shareable import codes are the deliverable, never source to commit.
xenon-creator-output/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Tauri native app — Rust build output and generated schemas/capabilities.
# (Cargo.lock and src-tauri/icons/ ARE committed once generated.)
apps/native/src-tauri/target/
apps/native/src-tauri/gen/

# OS
Thumbs.db
.DS_Store
desktop.ini

# IDE
.vscode/
.idea/
*.swp

# SoundVolumeView runtime artifacts
server/soundvolumeview-x64/out.csv
server/soundvolumeview-x64/tmp.csv
server/soundvolumeview-x64/*.cfg.bak

# PresentMon — downloaded by the installer for in-game FPS (not committed)
server/presentmon/

# Whisper.cpp — local STT binaries + model, downloaded on-demand by the
# dashboard (Settings → Xenon AI). Large, platform-specific, never committed.
server/whisper/

# User data — all runtime data (settings, notes, calendar, tasks, timers, deck,
# uploads, streaming tokens/config) lives in server/data/. Never commit it.
# Includes server-only secrets: stream-tokens.json (OAuth) and stream-config.json
# (owner-specific Twitch/YouTube client ids).
server/data/

# Legacy locations (pre-3.0, before data was centralized into server/data/) —
# kept ignored so any un-migrated leftover never gets committed.
server/notes.txt
server/events.json
server/settings.json
server/tasks.json
server/timers.json
server/deck.json
server/uploads/
server/stream-tokens.json
server/stream-config.json

# OpenRGB — local runtime artifacts, never commit these
server/openrgb/

# Xenon Helper — C# build artifacts; the published exe in server/helper/ is a
# build output (rebuilt from helper/ sources or downloaded with the release).
helper/bin/
helper/obj/
server/helper/

# Xenon backend Windows service (WinSW): the downloaded host exe, the per-machine
# generated config and the rolling logs. Only the template + scripts are versioned.
service/xenon-service.exe
service/xenon-service.xml
service/winsw-download.tmp
service/logs/

# Logs
*.log

# iCUE packaging scratch directory + packaged output (rebuild with `npm run icue:package`)
.icue-package/
xenonedgehub.icuewidget

# Superpowers brainstorming companion (local mockups)
.superpowers/

# Shared-code bridge: directory junctions server/shared and widget/shared →
# packages/core, recreated per checkout by `npm run link:shared` (postinstall).
# Never commit the junctions — packages/core is the single source of truth. The
# iCUE packaging step copies packages/core/src into the package instead.
server/shared/
widget/shared/

# Supporter-hub content keys emitted by the xenon-creator packager (upload then delete)
*-cek-secret.json
