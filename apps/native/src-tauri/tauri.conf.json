{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Xenon",
  "version": "4.0.0",
  "identifier": "com.marcimastro98.xenon",
  "build": {
    "frontendDist": "../splash"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Xenon",
        "url": "index.html",
        "width": 2560,
        "height": 720,
        "minWidth": 640,
        "minHeight": 240,
        "resizable": true,
        "decorations": false,
        "fullscreen": true,
        "alwaysOnTop": false,
        "visible": true,
        "focus": true,
        "center": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Marcello Mastroeni (marcimastro98)",
    "category": "Utility",
    "shortDescription": "Xenon kiosk for the CORSAIR Xeneon Edge",
    "longDescription": "Native full-screen Xenon dashboard for the CORSAIR Xeneon Edge display. Renders the same UI as the browser and the iCUE iframe, served by the local Xenon backend service on 127.0.0.1:3030.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
